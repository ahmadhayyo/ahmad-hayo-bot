# ============================================================
# HAYO AI Agent — Environment Configuration
# ============================================================
# 1. Copy this file:   copy .env.example .env
# 2. Fill in your API keys below
# 3. NEVER commit .env to version control
# ============================================================

# ── Model Provider ────────────────────────────────────────────────────────────
# Choose your default AI provider: "google", "anthropic", "openai", "deepseek", or "groq"
# You can switch providers at runtime using /model command in the chat UI
MODEL_PROVIDER=google

# ── Google Gemini ─────────────────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# Gemini model options:
#   gemini-2.5-flash          ← fast + powerful (recommended)
#   gemini-2.5-pro            ← most capable
#   gemini-2.0-flash          ← fast + free tier friendly
GOOGLE_AGENT_MODEL=gemini-2.5-flash
GOOGLE_SUMMARIZER_MODEL=gemini-2.0-flash

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Claude model options:
#   claude-sonnet-4-20250514  ← Claude Sonnet 4 (recommended)
#   claude-3-5-sonnet-20241022
#   claude-haiku-4-5-20251001 ← fast and affordable
ANTHROPIC_AGENT_MODEL=claude-sonnet-4-20250514
ANTHROPIC_SUMMARIZER_MODEL=claude-haiku-4-5-20251001

# ── OpenAI (ChatGPT) ─────────────────────────────────────────────────────────
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI model options:
#   gpt-4o                    ← most capable (recommended)
#   gpt-4o-mini               ← fast and affordable
#   gpt-4-turbo               ← previous generation
OPENAI_AGENT_MODEL=gpt-4o
OPENAI_SUMMARIZER_MODEL=gpt-4o-mini

# ── DeepSeek ──────────────────────────────────────────────────────────────────
# Get your key at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# DeepSeek model options:
#   deepseek-chat             ← general purpose (recommended)
#   deepseek-reasoner         ← deep reasoning
DEEPSEEK_AGENT_MODEL=deepseek-chat
DEEPSEEK_SUMMARIZER_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ── Groq ──────────────────────────────────────────────────────────────────────
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Groq model options:
#   llama-3.3-70b-versatile   ← most capable (recommended)
#   llama-3.1-8b-instant      ← ultra-fast
#   mixtral-8x7b-32768        ← Mixtral MoE
#   gemma2-9b-it              ← Google Gemma 2
GROQ_AGENT_MODEL=llama-3.3-70b-versatile
GROQ_SUMMARIZER_MODEL=llama-3.1-8b-instant

# ── Agent Behavior ────────────────────────────────────────────────────────────
# Maximum agent iterations before forced stop (default: 50, capped at 500)
MAX_ITERATIONS=100
# Maximum messages before context summarization triggers (default: 30, capped at 300)
MAX_HISTORY=50
# PowerShell/CMD command timeout in seconds (default: 120, capped at 300)
PS_TIMEOUT=120

# ── Browser ───────────────────────────────────────────────────────────────────
# Set to true to hide browser window during automation
BROWSER_HEADLESS=false

# ── Logging ───────────────────────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
