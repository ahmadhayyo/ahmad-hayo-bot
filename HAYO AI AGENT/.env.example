# ============================================================
# HAYO AI Agent — Environment Configuration
# ============================================================
# 1. Copy this file:   copy .env.example .env
# 2. Fill in your API keys below
# 3. NEVER commit .env to version control
# ============================================================

# ── Model Provider ────────────────────────────────────────────────────────────
# Choose your default AI provider: "google", "anthropic", "openai", "deepseek", "groq", or "ollama"
# You can switch providers at runtime using /model command in the chat UI
# Use "ollama" for free local AI (no API key needed!) — see Ollama section below
MODEL_PROVIDER=google

# ── Google Gemini ─────────────────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# Gemini model options:
#   gemini-2.5-flash          ← fast + powerful (recommended)
#   gemini-2.5-pro            ← most capable
#   gemini-2.0-flash          ← fast + free tier friendly
GOOGLE_AGENT_MODEL=gemini-2.5-flash
GOOGLE_SUMMARIZER_MODEL=gemini-2.0-flash

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Claude model options:
#   claude-sonnet-4-20250514  ← Claude Sonnet 4 (recommended)
#   claude-3-5-sonnet-20241022
#   claude-haiku-4-5-20251001 ← fast and affordable
ANTHROPIC_AGENT_MODEL=claude-sonnet-4-20250514
ANTHROPIC_SUMMARIZER_MODEL=claude-haiku-4-5-20251001

# ── OpenAI (ChatGPT) ─────────────────────────────────────────────────────────
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI model options:
#   gpt-4o                    ← most capable (recommended)
#   gpt-4o-mini               ← fast and affordable
#   gpt-4-turbo               ← previous generation
OPENAI_AGENT_MODEL=gpt-4o
OPENAI_SUMMARIZER_MODEL=gpt-4o-mini

# ── DeepSeek ──────────────────────────────────────────────────────────────────
# Get your key at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# DeepSeek model options:
#   deepseek-chat             ← general purpose (recommended)
#   deepseek-reasoner         ← deep reasoning
DEEPSEEK_AGENT_MODEL=deepseek-chat
DEEPSEEK_SUMMARIZER_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ── Groq ──────────────────────────────────────────────────────────────────────
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Groq model options:
#   llama-3.3-70b-versatile   ← most capable (recommended)
#   llama-3.1-8b-instant      ← ultra-fast
#   mixtral-8x7b-32768        ← Mixtral MoE
#   gemma2-9b-it              ← Google Gemma 2
GROQ_AGENT_MODEL=llama-3.3-70b-versatile
GROQ_SUMMARIZER_MODEL=llama-3.1-8b-instant

# ── Ollama (Free Local AI) ─────────────────────────────────────────────
# Ollama runs AI models locally on your machine — completely FREE!
# No API key needed. Just install Ollama and pull a model:
#   1. Install: https://ollama.com/download
#   2. Pull a model: ollama pull llama3.1
#   3. Set MODEL_PROVIDER=ollama above
#
# Ollama model options (run 'ollama list' to see installed models):
#   llama3.1      ← Meta Llama 3.1 (recommended, 8B)
#   llama3.2      ← Meta Llama 3.2 (lighter, 3B)
#   mistral       ← Mistral 7B
#   gemma2        ← Google Gemma 2
#   qwen2.5       ← Alibaba Qwen 2.5
#   phi3          ← Microsoft Phi-3
#   codellama     ← Meta Code Llama (for coding tasks)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_AGENT_MODEL=llama3.1
OLLAMA_SUMMARIZER_MODEL=llama3.1

# ── Agent Behavior ────────────────────────────────────────────────────────────
# Maximum agent iterations before forced stop (default: 50, capped at 500)
MAX_ITERATIONS=100
# Maximum messages before context summarization triggers (default: 30, capped at 300)
MAX_HISTORY=50
# PowerShell/CMD command timeout in seconds (default: 120, capped at 300)
PS_TIMEOUT=120

# ── Browser ───────────────────────────────────────────────────────────────────
# Set to true to hide browser window during automation
BROWSER_HEADLESS=false

# ── Logging ───────────────────────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ============================================================
# Integrations (التكاملات)
# ============================================================
# أضف مفاتيح API للخدمات التي تريد ربطها بالوكيل
# استخدم /connect <service> في الواجهة لرؤية تعليمات الإعداد
#
# ── GitHub ───────────────────────────────────────────────────────────────────
# Get a Personal Access Token at: https://github.com/settings/tokens
# Required scopes: repo, read:org
GITHUB_TOKEN=your_github_token_here

# ── Google Drive ─────────────────────────────────────────────────────────────
# Create OAuth credentials at: https://console.cloud.google.com/apis/credentials
# Enable Google Drive API first: https://console.cloud.google.com/apis/library/drive.googleapis.com
GOOGLE_DRIVE_CREDENTIALS_FILE=credentials.json

# ── Telegram Bot ─────────────────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── Slack ────────────────────────────────────────────────────────────────────
# Create a Slack App at: https://api.slack.com/apps
# Required scopes: chat:write, channels:read, files:write
SLACK_BOT_TOKEN=your_slack_bot_token_here

# ── Notion ───────────────────────────────────────────────────────────────────
# Create an integration at: https://www.notion.so/my-integrations
NOTION_API_KEY=your_notion_api_key_here

# ── Trello ───────────────────────────────────────────────────────────────────
# Get your API key at: https://trello.com/app-key
TRELLO_API_KEY=your_trello_api_key_here
TRELLO_TOKEN=your_trello_token_here

# ── Discord ──────────────────────────────────────────────────────────────────
# Create a bot at: https://discord.com/developers/applications
# Required permissions: Send Messages, Read Messages
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# ── Plugins (الإضافات) ──────────────────────────────────────────────────────
# Directory for custom plugins (default: plugins/ next to app.py)
# Each .py file in this directory that exports a TOOLS list will be loaded
# See plugins/example_plugin.py for a template
# PLUGINS_DIR=plugins
