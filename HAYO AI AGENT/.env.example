# ============================================================
# Ultimate Secure Local OS Executive Agent — Environment Config
# ============================================================
# 1. Copy this file:   copy .env.example .env
# 2. Fill in your values below
# 3. NEVER commit .env to version control

# ── Model Provider ────────────────────────────────────────────────────────────
# Choose your AI provider: "anthropic" or "google"
MODEL_PROVIDER=google

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Claude model options:
#   claude-3-7-sonnet-20250219   ← Claude Sonnet 3.7 (recommended)
#   claude-sonnet-4-5
#   claude-opus-4-6
ANTHROPIC_AGENT_MODEL=claude-3-7-sonnet-20250219
ANTHROPIC_SUMMARIZER_MODEL=claude-haiku-4-5-20251001

# ── Google Gemini ─────────────────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# Gemini model options:
#   gemini-2.0-flash          ← fast + free tier friendly (recommended)
#   gemini-2.0-flash-thinking ← deep reasoning
#   gemini-1.5-pro            ← long context
GOOGLE_AGENT_MODEL=gemini-2.0-flash
GOOGLE_SUMMARIZER_MODEL=gemini-2.0-flash

# ── Agent Behavior ────────────────────────────────────────────────────────────
# Maximum agent iterations before forced stop (default: 20)
MAX_ITERATIONS=20
# Maximum messages before context summarization triggers (default: 15)
MAX_HISTORY=15
# PowerShell command timeout in seconds (default: 120)
PS_TIMEOUT=120
