# ═══════════════════════════════════════════════════════════════════════════════
#  HAYO AI Agent — Android Edition — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
#
#  SETUP:
#  1. Copy this file: cp .env.example .env
#  2. Fill in at least ONE API key below
#  3. Set MODEL_PROVIDER to the provider you want to use
#
# ═══════════════════════════════════════════════════════════════════════════════

# ── Provider Selection ──────────────────────────────────────────────────────
# Options: google, anthropic, openai, deepseek
MODEL_PROVIDER=google

# ── Google Gemini ───────────────────────────────────────────────────────────
GOOGLE_API_KEY=
GOOGLE_AGENT_MODEL=gemini-2.5-flash
GOOGLE_SUMMARIZER_MODEL=gemini-2.0-flash

# ── Anthropic Claude ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_AGENT_MODEL=claude-sonnet-4-20250514
ANTHROPIC_SUMMARIZER_MODEL=claude-haiku-4-5-20251001

# ── OpenAI ChatGPT ──────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_AGENT_MODEL=gpt-4o
OPENAI_SUMMARIZER_MODEL=gpt-4o-mini

# ── DeepSeek ────────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=
DEEPSEEK_AGENT_MODEL=deepseek-chat
DEEPSEEK_SUMMARIZER_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ── Agent Settings ──────────────────────────────────────────────────────────
MAX_ITERATIONS=50
MAX_HISTORY=15
SHELL_TIMEOUT=120
